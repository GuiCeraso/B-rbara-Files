4) Classificação de Atletas
idade = int(input("Digite a idade do nadador: "))

if idade < 5:
    print("Muito jovem")
elif idade >= 5 and idade <= 7:
    print("Infantil A")
elif idade >= 8 and idade <= 10:
    print("Infantil B")
elif idade >= 11 and idade <= 17:
    print("Juvenil")
else:
    print("Sênior")
